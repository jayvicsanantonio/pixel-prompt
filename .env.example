# Analytics
# These are intentionally public browser values.
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_TOKEN=

# Persistence
# Server-only.
DATABASE_URL=
PIXEL_PROMPT_SUBMIT_RATE_LIMIT_BURST_MAX=8
PIXEL_PROMPT_SUBMIT_RATE_LIMIT_BURST_WINDOW_SECONDS=60
PIXEL_PROMPT_SUBMIT_RATE_LIMIT_SUSTAINED_MAX=30
PIXEL_PROMPT_SUBMIT_RATE_LIMIT_SUSTAINED_WINDOW_SECONDS=600

# AI providers
# Server-only.
OPENAI_API_KEY=
PIXEL_PROMPT_ENABLE_OPENAI_IMAGE_GENERATION=
PIXEL_PROMPT_ENABLE_OPENAI_SCORING=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_SCORING_MODEL=gpt-5.4-mini
PIXEL_PROMPT_GENERATED_OUTPUT_DIR=.pixel-prompt/generated-output
PIXEL_PROMPT_TARGET_ASSET_DIR=public

# Vercel Blob Storage
# Server-only. Used in production for persisted generated images.
BLOB_READ_WRITE_TOKEN=

